# Snowflake connection
SNOWFLAKE_ACCOUNT=your-account-identifier
SNOWFLAKE_DATABASE=your-database
SNOWFLAKE_WAREHOUSE=your-warehouse
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# Azure AD / Entra ID — service principal for Snowflake External OAuth
AZURE_TENANT_ID=your-tenant-guid
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
# Scope format: <APPLICATION_ID_URI>/.default
AZURE_SNOWFLAKE_SCOPE=api://your-app-name/.default

# Dev only — bypasses Snowflake connection entirely, returns mock data
# Must NOT be set to 'true' when NODE_ENV=production
SNOWFLAKE_MOCK=true
NODE_ENV=development

# Integration testing only — paste a valid Azure AD access token here to test Snowflake OAuth
# without needing AZURE_CLIENT_SECRET configured. Remove or leave empty in normal operation.
INTEGRATION_MSAL_ACCESS_TOKEN=
